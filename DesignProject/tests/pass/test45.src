// Test: Implementation block with multiple functions (implFuncs)
class Math {
    public attribute pi : float;
};

implement Math {
    func add(a : integer, b : integer) => integer {
        return (a + b);
    }
    
    func multiply(a : integer, b : integer) => integer {
        return (a * b);
    }
    
    constructor() {
        self.pi := 3.14;
    }
}

